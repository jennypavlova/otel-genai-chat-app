# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# .env is gitignored — NEVER commit real keys to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── OpenAI-compatible provider ────────────────────────────────────────────────
# Works with OpenAI, LiteLLM, or any OpenAI-compatible gateway.
OPENAI_API_KEY=your-api-key-here
# Leave blank to use the default OpenAI endpoint.
# For LiteLLM: OPENAI_BASE_URL=http://localhost:4000/v1
OPENAI_BASE_URL=
# Model name sent to the API.  Any model your provider supports.
OPENAI_MODEL=gpt-4o-mini

# ── OpenTelemetry ─────────────────────────────────────────────────────────────
OTEL_SERVICE_NAME=otel-genai-chat-app

# Option A — local OTel/EDOT collector (docker-compose):
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_EXPORTER_OTLP_HEADERS=
# Option B — Elastic Cloud managed OTLP endpoint (no collector needed):
# OTEL_EXPORTER_OTLP_ENDPOINT=https://<your-cluster>.apm.<region>.aws.found.io
# OTEL_EXPORTER_OTLP_HEADERS=Authorization=ApiKey <your-elastic-api-key>

OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf

# Capture prompt / response content as span events (great for Kibana APM inspection).
# Valid values: NO_CONTENT | SPAN_ONLY | EVENT_ONLY | SPAN_AND_EVENT
# Use NO_CONTENT if you have PII concerns.
OTEL_INSTRUMENTATION_GENAI_CAPTURE_MESSAGE_CONTENT=SPAN_AND_EVENT

# ── Local collector → Elasticsearch ──────────────────────────────────────────
# Used only by the docker-compose collector (otel-collector-config.yaml).
# Your local ES/Kibana stack endpoint and an API key with write access.
ELASTIC_ES_ENDPOINT=http://host.docker.internal:9200
ELASTIC_ES_API_KEY=your-elastic-api-key-here
