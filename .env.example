# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# .env is gitignored — NEVER commit real keys to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── OpenAI-compatible provider ────────────────────────────────────────────────
# Works with OpenAI, LiteLLM, or any OpenAI-compatible gateway.
OPENAI_API_KEY=your-api-key-here
# Leave blank to use the default OpenAI endpoint.
# For LiteLLM: OPENAI_BASE_URL=http://localhost:4000/v1
OPENAI_BASE_URL=
# Model name sent to the API.  Any model your provider supports.
OPENAI_MODEL=gpt-4o-mini

# ── OpenTelemetry ─────────────────────────────────────────────────────────────
OTEL_SERVICE_NAME=otel-genai-chat-app
# Environment label shown in Kibana APM environment filter (required for APM UI).
# Without this the service appears under "unknown" and the environment dropdown
# in APM Service Overview has nothing to filter on.
OTEL_DEPLOYMENT_ENVIRONMENT=development

# Additional resource attributes attached to every span.
# EDOT users: telemetry.distro.name=elastic is REQUIRED — it tells the APM
# backend the SDK is EDOT, which unlocks enriched service maps, transaction
# names, and the "Your OTel data is not fully enriched" resolution.
# Vanilla OTel users: omit telemetry.distro.name (comment out or remove).
OTEL_RESOURCE_ATTRIBUTES=telemetry.distro.name=elastic

# ── OTLP export destination ───────────────────────────────────────────────────
# Option A — local EDOT Collector (docker-compose, mirrors managed OTLP locally):
#   EDOT Collector writes to traces-generic.otel-* in OTel-native format
#   (gen_ai.* preserved as dotted names) AND generates service_transaction
#   metrics via the elasticapm connector → Kibana APM Service Inventory works.
#   Start with: docker compose up -d
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_EXPORTER_OTLP_HEADERS=

# Option B — Elastic Cloud managed OTLP endpoint (no local collector needed):
# OTEL_EXPORTER_OTLP_ENDPOINT=https://<your-cluster>.apm.<region>.aws.found.io
# OTEL_EXPORTER_OTLP_HEADERS=Authorization=ApiKey <your-elastic-api-key>

OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf

# Enable latest experimental GenAI semantic conventions.
# Required for SPAN_AND_EVENT content capture and for Kibana APM 9.x GenAI tab to show
# provider, model, and message content.  Without this the instrumentation uses the older
# path that ignores SPAN_AND_EVENT (only accepts the literal value "true").
OTEL_SEMCONV_STABILITY_OPT_IN=gen_ai_latest_experimental

# Capture prompt / response content as OTel log events.
# Valid values (only meaningful when OTEL_SEMCONV_STABILITY_OPT_IN is set above):
#   NO_CONTENT    — no message text (safe for PII-sensitive workloads)
#   SPAN_ONLY     — content stored as span attributes
#   EVENT_ONLY    — content emitted as OTel log events linked to the span
#   SPAN_AND_EVENT — content stored both ways (most visibility)
OTEL_INSTRUMENTATION_GENAI_CAPTURE_MESSAGE_CONTENT=SPAN_AND_EVENT

# ── Elasticsearch credentials ─────────────────────────────────────────────────
# Used by docker-compose (EDOT Collector → Elasticsearch output).
# Not needed if using Elastic Cloud managed OTLP (Option B above).
ELASTIC_ES_ENDPOINT=http://host.docker.internal:9200

# Option A — basic auth (default local stack: elastic / changeme)
ELASTIC_ES_USER=elastic
ELASTIC_ES_PASSWORD=changeme

# Option B — API key (Elastic Cloud or managed cluster)
# Comment out ELASTIC_ES_USER/PASSWORD above and uncomment this instead.
# ELASTIC_ES_API_KEY=your-elastic-api-key-here
